" 0
 E E E E 1 -1 -1 0  10 10
""0  1
E "function_ptr fpEvent;

dyn_string dsPanels;
dyn_string dsNames;
int iCurrentIndex = -1;
bool bCurrentSelection = FALSE;

public connectEvent(function_ptr _fpEvent)
{
  fpEvent = _fpEvent;

  uiConnect(\"selectionChanged\", fpEvent);
}

selectionChanged(const string &panel, const string &name)
{
  for (int i = 1; i <= dynlen(dsPanels); i++)
  {
    if (dsPanels[i] == panel && dsNames[i] == name)
    {
      setIcon(i, TRUE); //select the item
      return;
    }
  }
  setIcon(1, FALSE); //unselect and change to icon 1
}

setIcon(int iIndex=-1, bool bSelected = FALSE)
{
  bCurrentSelection = bSelected;
  if (iIndex != -1)
  {
    button.toolTipText = dsNames[iIndex];
    string sName = strtolower(dsNames[iIndex]);

    string sSvg = getPath(PICTURES_REL_PATH, \"faceplateTabIcons/\"+sName+\".svg\");

    if (sSvg != \"\")
      button.fill(\"[pattern,[fit,any,\" + \"faceplateTabIcons/\"+sName + \".svg]]\");

    if (iCurrentIndex != iIndex)
      iCurrentIndex = iIndex;

  }

  button.fillSvgElement(\"rBackground\", \"[solid]\", bSelected ? \"fp_tabHeaderSelected\" : \"fp_tabHeader\");
}

