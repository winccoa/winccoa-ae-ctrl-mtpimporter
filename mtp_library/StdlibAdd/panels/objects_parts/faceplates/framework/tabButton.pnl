E "main(mapping event)
{
  int iNextIndex;
  if (!bCurrentSelection)
    iNextIndex = 1;
  else //find next index
  {
    iNextIndex = iCurrentIndex + 1;
    if (iNextIndex > dynlen(dsPanels))
      iNextIndex = 1;
  }
  triggerEvent(fpEvent, dsPanels[iNextIndex], dsNames[iNextIndex], iNextIndex, dynlen(dsPanels));
}
