"main()
{
  dyn_string dpts = dpTypes(strtoupper(strsplit(PROJ, \"_\")[1]) + \"_*\");
  this.items(dpts);

  if ( this.selectedText() != \"\" )
    showPanelPath(this.selectedText());

  if ( dynlen(dpts) > 0 )
  {
    this.selectedPos = 1;
    exportBut.enabled(1);
    DPTreview.enabled(1);
    tabBut.enabled(1);
    symbolBut.enabled(1);
  }
}
