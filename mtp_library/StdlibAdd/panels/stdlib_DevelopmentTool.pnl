LANG:10027 14 Экспорт
"main(mapping event)
{
  this.enabled(0);

  if ( checkDPTlist() < 1 )
  {
    exportBut.enabled(0);
    tabBut.enabled(0);
    symbolBut.enabled(0);
    DPTreview.enabled(0);
    pathPanel.text(\"\");
    ChildPanelOnCentral(\"vision/MessageInfo1\",
                      getCatStr(\"general\",\"information\"),
                      makeDynString(getCatStr(\"stdlib\",\"stdLibStart\")));
    return;
  }

  dyn_string dpts;
  getValue(\"cbDpt\", \"items\", dpts);
  dynSortAsc(dpts);

  pathDPL.text(getCatStr(\"stdlib\",\"exporting\"));

  if ( dynlen(dpts) == 0 || stdlibExt_exportLibDpl(dpts) < 1 )
    pathDPL.text(getCatStr(\"stdlib\",\"noExport\"));

  this.enabled(1);
}
