"main()
{
  this.enabled(0);

  string tabName = txtTabName.text;
  strreplace(tabName, \".pnl\", \"\");

  if ( !dpIsLegalName(tabName) )
  {
    txtTabName.backCol(\"red\");
    delay(0, 200);
    txtTabName.backCol(\"\");

    ChildPanelOnCentral(\"vision/MessageInfo1\",
                        getCatStr(\"general\",\"warning\"),
                        makeDynString(getCatStr(\"stdlib\",\"nameErr\") + \"\\n\" + getCatStr(\"stdlib\",\"noSpecialChar\")));

    return;
  }

  if ( stdlibExt_createFaceplateTab(tabName, cbDpt.selectedText()) )
    ChildPanelOnCentral(\"vision/MessageInfo1\",
                        getCatStr(\"general\",\"information\"),
                        makeDynString(getCatStr(\"stdlib\",\"tabCreated\")));
  else
    ChildPanelOnCentral(\"vision/MessageInfo1\",
                        getCatStr(\"general\",\"information\"),
                        makeDynString(getCatStr(\"stdlib\",\"tabExists\")));

  this.enabled(1);
}

