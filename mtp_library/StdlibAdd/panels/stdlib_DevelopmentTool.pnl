"main()
{
  if ( dynlen(dpTypes(this.selectedText)) > 0 )
  {
    exportBut.enabled(1);
    tabBut.enabled(1);
    symbolBut.enabled(1);
    showPanelPath(this.selectedText());
  }
  else
  {
    if ( checkDPTlist() < 1 )
    {
      exportBut.enabled(0);
      tabBut.enabled(0);
      symbolBut.enabled(0);
      DPTreview.enabled(0);
      pathPanel.text(\"\");
      ChildPanelOnCentral(\"vision/MessageInfo1\",
                        getCatStr(\"general\",\"information\"),
                        makeDynString(getCatStr(\"stdlib\",\"stdLibStart\")));
    }
  }
