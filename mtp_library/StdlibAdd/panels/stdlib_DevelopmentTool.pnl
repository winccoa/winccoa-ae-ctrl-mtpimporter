string logs = \"\";

/*
  @author Grygorii Sokhrannyi
  Show the faceplate panel path and name for the given DPT name
  @param DPT Is the selected DPT
*/
void showPanelPath(string DPT)
{
  pathPanel.text(\"objects_parts/faceplates/\" + DPT + \"/\");
}

//--------------------------------------------------------------------------------

/*
  @author Grygorii Sokhrannyi
  Check if all DPTs exist and relevant.
  @return 1 - when check is done and there are some DPTs, 0 - when check is done and all DPTs are not relevant
*/
int checkDPTlist()
{
    dyn_string dpts;
    getValue(\"cbDpt\", \"items\", dpts);
    for (int i = 1; i<= dynlen(dpts); ++i)
    {
      if ( dynlen(dpTypes(dpts[i])) < 1 )
      {
        dynRemove(dpts, i);
        break;
      }
    }

    setValue(\"cbDpt\", \"items\", dpts);
    if ( dynlen(dpts) == 0 )
      return 0;

  return 1;
}

//--------------------------------------------------------------------------------

/*
  @author Grygorii Sokhrannyi
  Open file Editor window with workflow logs
*/
void openLogs()
{
  textEditor(\"text\", logs, \"readOnly\", true);
}

//--------------------------------------------------------------------------------

/*
  @author Grygorii Sokhrannyi
  Generate users hook library
*/
void generateLib()
{
  string destination = getPath(LIBS_REL_PATH);
  destination += strtolower(strsplit(PROJ, \"_\")[1]) + \"_hook.ctl\";

  if ( isfile(destination) )
    return;

  dyn_string stdlibFunctions = makeDynString(\"string hook_stdlib_getAlertElement(string &dp)\",
                                             \"string hook_stdlib_getInvalidElement(string &dp)\",
                                             \"string hook_stdlib_getOperationModeElement(string &dp)\",
                                             \"int hook_stdlib_alterInfoAreaDisplay(anytype &aParams)\",
                                             \"dyn_string hook_stdlib_getInfoAreaDPEs(anytype &aParams)\",
                                             \"bool hook_stdlib_hasDpeAnActiveAdress(string &DPE)\",
                                             \"dyn_anytype hook_stdlib_fillPopUpMenu(anytype &aParams)\",
                                             \"dyn_string hook_stdlib_addEnableRuleDpes(string &sDpe)\",
                                             \"dyn_string hook_stdlib_addVisibleRuleDpes(string &sDpe)\",
                                             \"dyn_string hook_stdlib_addHighlightRuleDpes(string &sDpe)\",
                                             \"bool hook_stdlib_libEnableElementarySymbol(dyn_anytype &aParams)\",
                                             \"bool hook_stdlib_libVisibleElementarySymbol(dyn_anytype &aParams)\",
                                             \"bool hook_stdlib_libHighlightElementarySymbol(dyn_anytype &aParams)\",
                                             \"bool hook_stdlib_libLicenseAvailable(string s=\\\"\\\")\",
                                             \"langString hook_stdlib_faceplateHeadline(string &sDp)\",
                                             \"langString hook_stdlib_faceplateWindowTitle(string &sDp)\");

  // Add function header
  string moment = getCurrentTime();
  string content = \"#uses \\\"stdlib_hook\\\"\\n\\n/*\\n  Automatically generated on \";
  content += moment;
  content += \" with Stdlib Development Panel\\n*/\";

  // Add functions
  for (int i = 1; i <= dynlen(stdlibFunctions); ++i)
  {
    strreplace(stdlibFunctions[i], \"_stdlib_\", \"_\" + strtolower(strsplit(PROJ, \"_\")[1]) + \"_\");
    content += \"\\n\\n\" + stdlibFunctions[i] + \"\\n{\\n  return \";
    strreplace(stdlibFunctions[i], \"string\", \"\");
    strreplace(stdlibFunctions[i], \"bool\", \"\");
    strreplace(stdlibFunctions[i], \"int \", \"\");
    strreplace(stdlibFunctions[i], \"langString\", \"\");
    strreplace(stdlibFunctions[i], \"anytype\", \"\");
    strreplace(stdlibFunctions[i], \"dyn_\", \"\");
    strreplace(stdlibFunctions[i], \"&\", \"\");
    strreplace(stdlibFunctions[i], \" \", \"\");
    strreplace(stdlibFunctions[i], \"_\" + strtolower(strsplit(PROJ, \"_\")[1]) + \"_\", \"_stdlib_\");
    content += stdlibFunctions[i];
    content += \";\\n}\";
  }

  // Write to a file
  file fileDest = fopen(destination, \"w\");
  fputs(content, fileDest);
  fclose(fileDest);

  logs += \"The library file \" + destination + \" has been generated.\\n\";
}

//--------------------------------------------------------------------------------

/*
  @authors Grygorii Sokhrannyi
  Create symbol of a given template for the given DPT
  @params:
    template Is the symbol template
    dpt Is the datapoint type
  @return the path where template panel is copied, suffix \"-\" means that the panel is already exists
*/
string stdlibExt_createSymbol(string template, string dpt)
{
  string destFile = template;
  strreplace(destFile, \"template\", \"\");

  dyn_string pathAndPanel;
  dptsGetSymbolsForDpt(dpt, pathAndPanel);

  for (int i = 1; i <= dynlen(pathAndPanel); ++i)
  {
    if ( pathAndPanel[i] == \"objects/\" + dpt + \"/\" + dpt + destFile )  // panel exists, do nothing
    {
      logs += \"The reference panel exists: panels/objects/\" + dpt + \"/\" + dpt + destFile + \"\\n\";
      return \"-panels/objects/\" + dpt + \"/\";
    }
  }
  string panelPath = \"objects/\" + dpt + \"/\" + dpt + destFile;

  dynAppend(pathAndPanel, panelPath);

  // Retrieve an icon for the given template
  string pictFile = destFile;
  strreplace(pictFile, \".pnl\", \".png\");

  string destImg = getPath(PANELS_REL_PATH) + \"objects/\" + dpt + \"/\" + dpt + destFile + \"/\" + dpt + pictFile,
         tempImg = template;

  destFile = getPath(PANELS_REL_PATH) + \"objects/\" + dpt + \"/\" + dpt + destFile;

  strreplace(destImg, getPath(PANELS_REL_PATH), getPath(IMAGES_REL_PATH));
  strreplace(tempImg, \".pnl\", \".png\");

  if ( !isfile(destFile) )
  {
    // Save the template panel in the project
    copyFile(getPath(PANELS_REL_PATH, \"objects/STDLIB_template/\" + template), destFile);

    // Save the tamplate icon in the project
    copyFile(getPath(IMAGES_REL_PATH, \"objects/STDLIB_template/\" + template + \"/\" + tempImg), destImg);
  }

  logs += \"The reference panel has been created: \" + panelPath + \"\\n\";

  // Set ref panels to the given DPT as symbols
  dptsSetSymbolsForDpt(dpt, pathAndPanel);

  return \"panels/objects/\" + dpt + \"/\";
}

//--------------------------------------------------------------------------------

/*
  @authors Markus Trummer
  Create a config.level file
*/
void stdlibExt_createConfig()
{
  string configLevel = getPath(CONFIG_REL_PATH) + \"config.level\";
  string hookCtlName = strtolower(strsplit(PROJ, \"_\")[1]) + \"_hook.ctl\";
  string configLevelContent;

  // Check if confi.level does already exist
  if ( access(configLevel, F_OK) == 0 )
  {
    fileToString(configLevel, configLevelContent);

    if ( strpos(configLevelContent, hookCtlName) > 0 ) // config entry already set, nothing more to do
      return;
  }

  // Add the created HOOK lib name to the config
  stdlibExt_addConfigEntry(configLevelContent, \"ui\", \"LoadCtrlLibs = \\\"\" + hookCtlName + \"\\\"\");
  stdlibExt_addConfigEntry(configLevelContent, \"ctrl\", \"LoadCtrlLibs = \\\"\" + hookCtlName + \"\\\"\");

  file configFile = fopen(configLevel, \"w\");
  fputs(configLevelContent, configFile);
  fclose(configFile);

  // Create messages for the Log
  logs += \"config.level has been created in \" + getPath(CONFIG_REL_PATH) + \"\\n\";
}

//--------------------------------------------------------------------------------

/*
  @authors Markus Trummer
  Add the given config entry to the config.level file
  @params:
     configFileContent Is the content of the config.level file
     section Is the config section to which the entry to be added
     line Is the entry which should be added to the file
*/
stdlibExt_addConfigEntry(string &configFileContent, string section, string line)
{
  section = \"[\" + section + \"]\";

  // Check if the section does exist and get its position
  int sectionPos = strpos(configFileContent, section);

  // Add the entry for the given section
  if ( sectionPos < 0 )  // section does not exist, will be added with the entry
  {
    configFileContent += \"\\n\\n\" + section + \"\\n\" + line;
  }
  else  // section exists, entry will be added to it
  {
    int insertPos = strpos(configFileContent, \"\\n\", sectionPos);
    configFileContent = substr(configFileContent, 0, insertPos) + \"\\n\" + line + \"\\n\" + substr(configFileContent, insertPos + 1);
  }
}

//--------------------------------------------------------------------------------

/*
  @authors Markus Trummer
  Import the necessary STDLib DPEs to the project
*/
stdlibExt_importSdllibDpl()
{
  string stdlibDplPath,
         asciiTool = getComponentName(ASCII_COMPONENT),
         asciiPath;

  stdlibDplPath = getPath(DPLIST_REL_PATH, \"stdlib.dpl\");

  if ( _WIN32 )
    asciiTool += \".exe\";

  asciiPath = getPath(BIN_REL_PATH, asciiTool);

  system(makeMapping(\"program\", asciiPath,
                     \"arguments\", makeDynString(\"-in\", stdlibDplPath)));
}

//--------------------------------------------------------------------------------

/*
  @authors Markus Trummer
  Create the given DPT and a master DPE
  @param DPTname Is the DPT name
*/
stdlibExt_createDPTs(string DPTname)
{
  string stdlibname = strtoupper(strsplit(PROJ, \"_\")[1]);
  dyn_dyn_int DPTstructure;
  dyn_dyn_string DPTStructurenames;
  dyn_errClass err;
  string DPT = stdlibname + \"_\" + DPTname;

  DPTStructurenames[1] = makeDynString(DPT, \"\", \"\");
  DPTStructurenames[2] = makeDynString(\"\", \"state\", \"\");
  DPTStructurenames[3] = makeDynString(\"\", \"alarm\", \"\");
  DPTStructurenames[4] = makeDynString(\"\", \"command\", \"\");
  DPTStructurenames[5] = makeDynString(\"\", \"para\", \"\");
  DPTStructurenames[6] = makeDynString(\"\", \"general\", \"\");
  DPTStructurenames[7] = makeDynString(\"\", \"\", \"note\", \"_STDLIB_Note\", \"\");
  DPTStructurenames[8] = makeDynString(\"\", \"operationMode\", \"_STDLIB_OMD\", \"\");

  DPTstructure[1] = makeDynInt(DPEL_STRUCT);
  DPTstructure[2] = makeDynInt(0, DPEL_STRUCT);
  DPTstructure[3] = makeDynInt(0, DPEL_STRUCT);
  DPTstructure[4] = makeDynInt(0, DPEL_STRUCT);
  DPTstructure[5] = makeDynInt(0, DPEL_STRUCT);
  DPTstructure[6] = makeDynInt(0, DPEL_STRUCT);
  DPTstructure[7] = makeDynInt(0, 0, DPEL_TYPEREF);
  DPTstructure[8] = makeDynInt(0, DPEL_TYPEREF);

  // Create DPT
  if ( dynlen(dpTypes(DPT)) < 1 )
    dpTypeCreate(DPTStructurenames, DPTstructure);

  // Create master DP
  if ( !dpExists(\"_mp_\" + DPT) )
    mpCreateMpDp(DPT, 1, FALSE);

  // Check if any errors occurred
  err = getLastError();
  if ( dynlen(err) > 0 )  // if any errors -> open the Dialog and stop
  {
    errorDialog(err);
    return;
  }

  // Configure summary alarm handler
  stdlibExt_insertSummaryAlarm(\"_mp_\" + DPT);
}

//--------------------------------------------------------------------------------

/*
  @author Markus Trummer
  Create the alarm handling for the given DPE
  @param DPE Is the DPE name
*/
private stdlibExt_insertSummaryAlarm(string DPE)
{
  dyn_string leaf, attributes;
  DPE = dpSubStr(DPE, DPSUB_DP);

  dpGet(\"_dt_\" + dpTypeName(DPE) + \".Leaf:_online.._value\", leaf,
        \"_dt_\" + dpTypeName(DPE) + \".DynamicAttribute:_online.._value\", attributes);

  dynAppend(leaf, DPE + \".alarm:_alert_hdl\");
  dynAppend(attributes, \"_da_none\");

  dpSet(DPE + \".alarm:_alert_hdl.._type\",DPCONFIG_SUM_ALERT);
  dpSet(DPE + \".alarm:_alert_hdl.._dp_pattern\", \"{\" + DPE + \".alarm.**,\" + DPE + \".state.**}\");
  dpSet(DPE + \".alarm:_alert_hdl.._active\",true);

  dpSet(\"_dt_\" + dpTypeName(DPE) + \".Leaf:_original.._value\", leaf,
        \"_dt_\" + dpTypeName(DPE) + \".DynamicAttribute:_original.._value\", attributes);
}

//--------------------------------------------------------------------------------

/*
  @author Markus Trummer
  Create the main panel or a tab panel of the given name related to the given DPT
  @params:
    tabName Is the template panel name
    DPT Is the Datapoint Type name
  @return If faceplate created - TRUE, otherwise - FALSE
*/
bool stdlibExt_createFaceplateTab(string tabName, string DPT = \"\")  // not a general faceplate tab if DPT != \"\"
{
  // Create folder if does not exist
  string folder = getPath(PANELS_REL_PATH) + \"objects_parts/faceplates/\";
  if ( DPT != \"\" )
    folder += DPT + \"/\";

  if ( access(folder, F_OK) != 0)  // folder does not exist
    mkdir(folder);

  string sourceFile;

  if ( tabName == \"main.pnl\" )
    sourceFile = getPath(PANELS_REL_PATH, \"/objects_parts/faceplates/template/main.pnl\");
  else
    sourceFile = getPath(PANELS_REL_PATH, \"/objects_parts/faceplates/template/tab.pnl\");

  if ( strpos(tabName, \".\") < 0 )  // no given extension
    tabName += \".pnl\";

  if ( !isfile(folder + tabName) )  // does not exist
    copyFile(sourceFile, folder + tabName);
  else
  {
    // Create messages for the Log
    logs += \"The faceplate panel exists: panels/objects_parts/faceplates/\" + tabName + \"\\n\";
    return false;
  }

  // Create messages for the Log
  logs += \"The faceplate panel has been created: panels/objects_parts/faceplates/\" + tabName + \"\\n\";
  return true;
}

//--------------------------------------------------------------------------------

/*
  @author Grygorii Sokhrannyi
  Export the given DPT and its DPEs to the file
  @param: DPTname Is the Datapoint type
  @return: Exist status, 0 - Error, 1 - No Errors
*/
bool stdlibExt_exportLibDpl(dyn_string DPTname)
{
  string asciiTool = getComponentName(ASCII_COMPONENT);
  if ( _WIN32 )
    asciiTool += \".exe\";

  string commandLine;
  string asciiPath = getPath(BIN_REL_PATH, asciiTool);
  string dplistPath = getPath(DPLIST_REL_PATH);
  string logPath = getPath(LOG_REL_PATH);
  string tempFile = dplistPath + \"additional_ascii_dump_tempfile.dpl\";

  tempFile = makeNativePath(tempFile);

  dyn_string dpeNames;
  string type, DT, DS;

  for (int i = 1; i <= dynlen(DPTname); ++i)
   dynAppend(dpeNames, dpNames(\"*\", DPTname[i]));

  type += \" -filterDpType _STDLIB_Note -filterDpType _STDLIB_OMD\";

  for (int i = 1; i <= dynlen(DPTname); ++i)
  {
    type += \" -filterDpType \" + DPTname[i];

    if ( _WIN32 )
    {
      DT += \" -filterDp _dt_\" + DPTname[i] + \";\";
      DS += \" -filterDp _ds_\" + DPTname[i] + \";\";
    }
    else
    {
      DT += \" -filterDp '_dt_\" + DPTname[i] + \";'\";
      DS += \" -filterDp '_ds_\" + DPTname[i] + \";'\";
    }
  }

  type = strrtrim(type, \" \");
  DT =   strrtrim(DT, \" \");
  DS =   strrtrim(DS, \" \");

  string asciifile = getPath(DPLIST_REL_PATH) + strsplit(PROJ, \"_\")[1] + \"_stdlib.dpl\";

  asciifile = makeNativePath(asciifile);

  // Form an ASCII export command to be executed
  for (int i = 1; i <= 2; ++i)  // two system commands loop (1st - export DPEs, 2nd - export DPTypes)
  {
    commandLine = makeNativePath(asciiPath);

    if ( i > 1 )
    {
      commandLine += \" -out \" + \"\\\"\" + tempFile + \"\\\"\";
      commandLine += \" -filter DO\";
    }
    else
    {
      commandLine += \" -out \" + \"\\\"\" + asciifile + \"\\\"\";
      commandLine += \" -filter TDAOHP\";
    }

    commandLine += type;

    if ( i > 1 )
    {
      commandLine += \" -filterDpType _DynamicDatapoints -filterDpType _DynamicDptSettings\";
      commandLine += DT;
      commandLine += DS;
    }
    else
    {
      dynSortAsc(dpeNames);
      for (int w = 1; w <= dynlen(dpeNames); ++w)
      {
        if ( _WIN32 )
          commandLine += \" -filterDp \" + dpSubStr(dpeNames[w], DPSUB_DP) + \";\";
        else
          commandLine += \" -filterDp '\" + dpSubStr(dpeNames[w], DPSUB_DP) + \";'\";
      }
    }

    commandLine += \" -log +stderr -log -file > \" + logPath + \"WCCOAascii_info.log 2> \" + logPath + \"WCCOAascii_log.log\";

    system(commandLine);

    if ( i > 1 )
    {
      string content;
      fileToString(tempFile, content);

      // Add temporary file content to main asciifile
      file fileDest = fopen(asciifile, \"a\");
      fputs(content, fileDest);
      fclose(fileDest);
    }
  }

  // Create messages for the Log
  logs += \"DPT has been exported to a file: \" + asciifile + \"\\n\";
  pathDPL.text(asciifile);

  remove(tempFile); // delete temporary file
  return 1;
}

