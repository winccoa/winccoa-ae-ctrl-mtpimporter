"main(mapping event)
{
  // Check if DPT name is set correctly
  if ( !dpIsLegalName(txtDPT.text) )
  {
    txtDPT.backCol(\"red\");
    delay(0, 200);
    txtDPT.backCol(\"\");

    //ChildPanelOnCentral(\"vision/MessageWarning\", \"Warn\", makeDynString(\"The name is empty or incorrect!\\nPlease don't use any special characters.\"));

    ChildPanelOnCentral(\"vision/MessageInfo1\",
                        getCatStr(\"general\",\"warning\"),
                        makeDynString(getCatStr(\"stdlib\",\"nameErr\") + \"\\n\" + getCatStr(\"stdlib\",\"noSpecialChar\")));
    return;
  }
  else if ( dynlen(dpTypes(strtoupper(strsplit(PROJ, \"_\")[1]) + \"_\" + txtDPT.text)) > 0 )
  {
    txtDPT.backCol(\"red\");
    delay(0, 200);
    txtDPT.backCol(\"\");

    // Create messages for the Log
    logs += \"The data point type '\" + strtoupper(strsplit(PROJ, \"_\")[1]) + \"_\" + txtDPT.text + \"' already exists.\\n\";

    ChildPanelOnCentral(\"vision/MessageInfo1\",
                        getCatStr(\"general\",\"information\"),
                        makeDynString(getCatStr(\"stdlib\",\"dptExist\")));
    return;
  }

  stdlibExt_createDPTs(txtDPT.text);  // run Create DPT function

  // Show DPT name on the panel and put in log
  dyn_string dpts;
  getValue(\"cbDpt\", \"items\", dpts);

  dynAppend(dpts, strtoupper(strsplit(PROJ, \"_\")[1]) + \"_\" + txtDPT.text);
  showPanelPath(strtoupper(strsplit(PROJ, \"_\")[1]) + \"_\" + txtDPT.text);

  setValue(\"cbDpt\", \"items\", dpts);
  cbDpt.selectedPos = dynlen(dpts);

  // Create messages for the Log
  logs += \"The data point type has been created with the name: \" + strtoupper(strsplit(PROJ, \"_\")[1]) + \"_\" + txtDPT.text + \"\\n\";

  dyn_float resultFloat;
  dyn_string resultString;

  ChildPanelOnCentralModalReturn(\"vision/MessageInfo1\",
                      getCatStr(\"general\",\"information\"),
                      makeDynString(getCatStr(\"stdlib\",\"dptCreated\") + \"\\n\" + getCatStr(\"stdlib\",\"editIt\")),
                      resultFloat,
                      resultString);

  stdlibExt_createFaceplateTab(\"main.pnl\", strtoupper(strsplit(PROJ, \"_\")[1]) + \"_\" + txtDPT.text);  // run Create Faceplate function

  // Enable DP Type and Export buttons
  DPTeff.visible(1);
  DPTeff.start();

  delay(2);  // animation duration

  DPTeff.stop();
  DPTeff.visible(0);

  exportBut.enabled(1);
  DPTreview.enabled(1);
  tabBut.enabled(1);
  symbolBut.enabled(1);
}
