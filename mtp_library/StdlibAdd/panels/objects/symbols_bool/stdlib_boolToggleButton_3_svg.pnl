"main()
{
  setMultiValue(\"txtOn\", \"text\", tr(\"On\"),
                \"txtOff\", \"text\", tr(\"Off\"),
                \"txtLabel\", \"text\", tr($TEXT));

  //get dollar parameter
  if($_INT_Bit!=\"\")
    iBit=$_INT_Bit;

  if($_BIT_NUMBER!=\"\")
    iBitNumber = $_BIT_NUMBER;
  if((iBit!=33)&&(iBit<31)&&(iBit>=0))
    bActiveBit=TRUE;

  sDPE=initializeElementarySymbolView($DP,$DPE,$_DPE_Visible,$_RULE_Visible,$_DPE_Enable,$_RULE_Enable,$_DPE_Highlight,$_RULE_Highlight);

  if ($_DPE_SET != \"\")
  {
    dpConnect(\"showTimerCB\", $DP + $_DPE_SET + \":\" + sTimerConfigAttribute, $DP + $_DPE_SET + \":_original.._stime\");
  }
}
