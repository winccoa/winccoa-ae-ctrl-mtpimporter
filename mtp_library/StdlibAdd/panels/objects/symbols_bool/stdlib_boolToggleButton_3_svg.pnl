""0  1
E "mapping mLastState;
int iBit=33;
string sDPE;
bool bActiveBit=FALSE;

string bitStruct = \"command.bit\";
string sBack,sFore;
langString lsFont;
bit32 bitBit;

langString lsTextEnum;
int iBitNumber = -1;

//current state
bool bEnabled;
bool bState; //on or off

const string sTimerConfigAttribute = \"_original.._userbit30\";
const int iTimeout = 10;

panelSetVisibility(bool bVisible)
{
  setMultiValue(\"txtOn\", \"visible\", bVisible,
                \"txtOff\", \"visible\", bVisible);
}
panelSetEnabled(bool _bEnable)
{
  bEnabled = _bEnable;
  visualizeButtonState();
}
panelSetHighlighting(bool bHighlight)
{
}
panelSetValue(anytype aValue)
{
  bool buttonIn;

  if( iBitNumber != -1 )
  {
    bit32 pattern = (bit32)aValue;
    bState = getBit(pattern, iBitNumber);
  }
  else
    bState = (bool)aValue;

  visualizeButtonState();
}

visualizeButtonState()
{
  setMultiValue(\"rOnClick\", \"enabled\", bEnabled && !bState,
                \"rOffClick\", \"enabled\", bEnabled && bState,
                \"rOn\", \"fillSvgElement\", \"rBackground\", \"[solid]\", getColorForState(bEnabled && !bState, bState),
                \"rOff\", \"fillSvgElement\", \"rBackground\", \"[solid]\", getColorForState(bEnabled && bState, !bState)
                );
}

string getColorForState(bool bEnabled, bool bActive)
{
  return \"fp_elemSymbol_\" + (bActive ? \"on\" : \"off\") +(bEnabled ? \"\": \"Disabled\");
}


clickedButon(bool bOn)
{
  if ($_DPE_SET != \"\")
  {
      dpSet($DP + $_DPE_SET, bOn,
            $DP + $_DPE_SET + \":\" + sTimerConfigAttribute, TRUE);
  }
  else
  {
    if(iBitNumber!=-1)
    {
      dpGet(sDPE, bitBit);
      setBit(bitBit,iBitNumber,bOn);
      dpSet(sDPE, bitBit);
    }
    else
    {
      dpSet(sDPE, bOn);
    }
  }
}

int iThreadId = -1;
showTimerCB(string s, bool bOn, string s2, time tTrigger)
{
  synchronized (iThreadId)
  {
    if (!bOn)
    {
      if (iThreadId != -1)
        stopThread(iThreadId);
      iThreadId = -1;

      setValue(\"txtTimer\", \"visible\", FALSE);
      return;
    }
    time tTarget = tTrigger + iTimeout;
    time tNow = getCurrentTime();

    if (tNow < tTarget)
    {
      int iSec = second(tTarget - tNow);

      if (iThreadId != -1)
        stopThread(iThreadId);


      iThreadId = startThread(\"showTimerThread\", iSec);
    }
  }
}

showTimerThread(int iSec)
{
  for (; iSec>=0; iSec--)
  {
    setValue(\"txtTimer\", \"text\", tr(\"Timeout in \") + iSec,
                         \"visible\", TRUE);
    delay(1);
  }
  setValue(\"txtTimer\", \"text\", tr(\"Timeout command!\"),
                       \"visible\", TRUE);

  synchronized (iThreadId)
  {
    iThreadId = -1;
  }
}

