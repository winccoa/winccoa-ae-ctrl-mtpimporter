E "#uses \"classes/MTP_BinManCfl/MTP_BinManCfl\"

shared_ptr<MTP_BinManCfl> viewModel;

public void initialize()
{
  if (viewModel == nullptr)
  {
    if (hasMethod(self.parentPanel(), \"getObjectPointer\"))
    {
      shared_ptr<MTP_BinManCfl> parentViewModel = self.parentPanel().getObjectPointer();

      if (parentViewModel != nullptr)
      {
        viewModel = parentViewModel;
      }
      else
      {
        viewModel = new MTP_BinManCfl($DP);
      }
    }
    else
    {
      viewModel = new MTP_BinManCfl($DP);
    }
  }
}

public shared_ptr<MTP_BinManCfl> getObjectPointer()
{
  return viewModel;
}

