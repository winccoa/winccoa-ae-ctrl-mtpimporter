"main()
{
  float fValue;
  langString lsUnit;
  string sMsgTolTipText;
  //get dollar parameter
  sMsgCat    = $_MSGCAT;
  if($_BOOL_Label!=\"\")
    bLabel     = strtolower($_BOOL_Label);
  sLabel     = $_MSGTEXT_Label;
  if($_BOOL_ShowUnit!=\"\")
    bUnit      = strtolower ($_BOOL_ShowUnit);
  if($_BOOL_ShowAlarm!=\"\")
    bShowAlarm = strtolower ($_BOOL_ShowAlarm);
  if($_BOOL_EnableInput!=\"\")
    bInput     = strtolower ($_BOOL_EnableInput);
  if($_MSGTOOLTIP_Textfield!=\"\")
    sMsgTolTipText = $_MSGTOOLTIP_Textfield;
  lsFont     = $_FONT_Text;
  if($_BOOL_UseDpeRange!=\"\")
    bUseRange=strtolower($_BOOL_UseDpeRange);
  if($_FLOAT_Range_Max!=\"\")
  {
    bNewMaxRange=TRUE;
    fRangeMax=$_FLOAT_Range_Max;
    sRangeMax=$_FLOAT_Range_Max;
  }
  if($_FLOAT_Range_Min!=\"\")
  {
    bNewMinRange=TRUE;
    fRangeMin=$_FLOAT_Range_Min;
    sRangeMin=$_FLOAT_Range_Min;
  }
  if(sMsgTolTipText!=\"\")
    aktuell.toolTipText=getCatStr(sMsgCat,sMsgTolTipText);
  if($_BOOL_UseDpeFormat!=\"\")
    bUseFormat=strtolower($_BOOL_UseDpeFormat);
//   if($_STRING_Format!=\"\")
//     sFormat=$_STRING_Format;
  if($_DPE_Range_Max!=\"\")
  {
    bUseMaxDPE = true;
    sDpeRangeMax = $_DPE_Range_Max;
  }
  if($_DPE_Range_Min!=\"\")
  {
    bUseMinDPE = true;
    sDpeRangeMin = $_DPE_Range_Min;
  }

  sDPE=initializeElementarySymbolView($DP,$DPE,$_DPE_Visible,$_RULE_Visible,$_DPE_Enable,$_RULE_Enable,$_DPE_Highlight,$_RULE_Highlight);
  string dpeFormat = dpGetFormat(sDPE);
  if(bUseFormat && dpeFormat!=\"\")
    aktuell.format(dpeFormat);
  if(lsFont!=\"\")
  {
    aktuell.font(lsFont);
    setValue(\"unit\",\"font\",lsFont);
    setValue(\"label\",\"font\",lsFont);
  }
  //if the config entry is true the aktuell field is editable
  // cschnedl: functionality in ScopeLib::panelSetEnabled
  // aktuell.enabled(bInput);
  if(bUnit)
  {
    lsUnit=dpGetUnit(sDPE);
    if(lsUnit!=\"\")
    {
      unit.text(\"[\"+lsUnit+\"]\");
      unit.visible(TRUE);
    }
  }
  if(bLabel)
  {
    label.visible(TRUE);
    label.text=getCatStr(sMsgCat,sLabel);
  }

  if(bShowAlarm)
    dpConnect(\"alarm\",sDPE+\":_online.._value\",
                      sDPE+\":_original.._invalid\",
                      sDPE+\":_alert_hdl.._active\",
                      sDPE+\":_alert_hdl.._act_state_color\");
}
alarm(string sDP1, bool   bValue,
      string sDP2, bool   bInvalid,
      string sDP3, bool   bActiv,
      string sDP4, string sColor)
{
  int i;
  if(sColor==\"\")
    setValue(\"aktuell\",\"backCol\",\"\");
  else
  {
    if (bActiv)
    {
      setValue(\"aktuell\",\"backCol\",sColor);
    }
  }
}
