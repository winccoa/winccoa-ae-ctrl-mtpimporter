2 "0.2f" 3 0 0 2 0 -1  "main()
{
  if(bInput)
  {
    string sTitle = dpGetDescription(sDPE);
    if (sTitle==\"\")
      sTitle = sDPE;
    // when using min/max from two separate dpe, override bUseRange to \"false\" so that _pv_range will not be evaluated
    // if you wish to change this, you have to edit STD_INPUTS/NumBlock.pnl for getting max minrange and min maxrange.
    // e.g. _pv_range is from 5-10 and min/max from DPE are 7-20, valid values should be 7-10. (cschnedl)
    if (bUseMinDPE)
    {
      bUseRange = false;
      dpGet(mergeDPE($DP, sDpeRangeMin), sRangeMin);
    }
    
    if (bUseMaxDPE)
    {
       bUseRange = false;
      dpGet(mergeDPE($DP, sDpeRangeMax), sRangeMax);
    }
    
    if(dpElementType(sDPE) == DPEL_BOOL)
    {
      sRangeMin=0;
      sRangeMax=1;
    }
      
    ChildPanelOnCentral(\"objects_parts/STD_INPUTS/NumBlock.pnl\", sTitle, 
                        makeDynString(\"$dpe_value:\"+sDPE,\"$_BOOL_ShowUnit:\"+bUnit,\"$_BOOL_UseDpeRange:\"+bUseRange,\"$_FLOAT_Range_Max:\"+sRangeMax,
                                      \"$_FLOAT_Range_Min:\"+sRangeMin,\"$_BOOL_UseDpeFormat:\"+bUseFormat)/*,\"$_STRING_Format:\"+sFormat)*/);
  }
}
" 0
 E "main()
{
  float fValue,fMax,fMin;
  dyn_errClass err;
   
  fValue=aktuell.text();
  //IM 91649  
  if (bUseMinDPE && bUseMaxDPE)
  {
    int dpeValMin, dpeValMax;
    dpGet(mergeDPE($DP, sDpeRangeMin), dpeValMin, mergeDPE($DP, sDpeRangeMax), dpeValMax);
    if (fValue > dpeValMax)
    {
      ChildPanelOnCentralModal(\"vision/MessageWarning\", \"Warning\",
                                 makeDynString(getCatStr(\"STD\", \"Text3\")+\"\\n\"+fValue+\" > \"+dpeValMax+\" !!\"));
      return;
    }
    if (fValue < dpeValMin)
    {
      ChildPanelOnCentralModal(\"vision/MessageWarning\", \"Warning\",
                                 makeDynString(getCatStr(\"STD\", \"Text3\")+\"\\n\"+fValue+\" < \"+dpeValMin+\" !!\"));
      return;
    }
    dpSetWait(sDPE+\":_original.._value\",fValue);
      err = getLastError();
      if (dynlen(err) > 0)
        errorDialog(err);
      
    return;
  }
  
  if(bUseRange)
  {
    dpGet(sDPE+\":_pv_range.._type\",iRange);
    if(iRange!=0)
    {
      bCheck = TRUE;
      dpGet(sDPE+\":_pv_range.._min\",fMin,
            sDPE+\":_pv_range.._max\",fMax);
      if(fValue>fMax)// newValue im Wertebereich ?
      {
        bCheck=FALSE;// Wert nicht verändern 
        ChildPanelOnCentralModal(\"vision/MessageWarning\", \"Warning\",
                                 makeDynString(getCatStr(\"STD\", \"Text3\")+\"\\n\"+fValue+\" > \"+fMax+\" !!\"));
      }
      if(fValue<fMin)// newValue im Wertebereich ?
      {
        bCheck=FALSE;// Wert nicht verändern 
        ChildPanelOnCentralModal(\"vision/MessageWarning\", \"Warning\",
                                 makeDynString(getCatStr(\"STD\", \"Text3\")+\"\\n\"+fValue+\" < \"+fMin+\" !!\"));
      }
    }
    if(bCheck)
    {
      dpSetWait(sDPE+\":_original.._value\",fValue);
      err = getLastError();
      if (dynlen(err) > 0)
        errorDialog(err);
   
    }
  }
  else
  {
    if(bNewMaxRange)
    {
      bCheck = TRUE;
      if(fValue>fRangeMax)// newValue im Wertebereich ?
      {
        bCheck=0;// Wert nicht verändern 
        ChildPanelOnCentralModal(\"vision/MessageWarning\", \"Warning\",
                                 makeDynString(getCatStr(\"STD\", \"Text3\")+\"\\n\"+fValue+\" > \"+fRangeMax+\" !!\"));
      }
      if(bCheck)
      {
        dpSetWait(sDPE+\":_original.._value\",fValue);
        err = getLastError();
        if (dynlen(err) > 0)
          errorDialog(err);
      }
    }
    if(bNewMinRange)
    {
      bCheck = TRUE;
      if(fValue<fRangeMin)// newValue im Wertebereich ?
      {
        bCheck=0;// Wert nicht verändern 
        ChildPanelOnCentralModal(\"vision/MessageWarning\", \"Warning\",
                                 makeDynString(getCatStr(\"STD\", \"Text3\")+\"\\n\"+fValue+\" < \"+fRangeMin+\" !!\"));
      }
      if(bCheck)
      {
        dpSetWait(sDPE+\":_original.._value\",fValue);
        err = getLastError();
        if (dynlen(err) > 0)
          errorDialog(err);
      }
    }
    else  
      dpSet(sDPE+\":_original.._value\",fValue);
    }
  
}
