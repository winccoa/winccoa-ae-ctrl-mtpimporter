E "mapping mLastState;
string sDPE,sLabel,sFormat=\"\",sMsgCat;
int iRange;
float fRangeMax,fRangeMin;
string sRangeMax=\"\",sRangeMin=\"\";
bool bUnit=TRUE,bCheck=TRUE, bShowAlarm=FALSE, bInput=TRUE, bLabel=FALSE,bUseRange=TRUE,bUseFormat=FALSE,bNewMaxRange=FALSE,bNewMinRange=FALSE;
bool bUseMinDPE = false;
bool bUseMaxDPE = false;
string sDpeRangeMin, sDpeRangeMax;
langString lsFont;
panelSetVisibility(bool bVisible)
{ 
  aktuell.visible(bVisible);
  if (bUnit)
    unit.visible(bVisible);
  if (bLabel)
    label.visible(bVisible);
}
panelSetEnabled(bool bEnable)
{
//   if(!bEnable)
//     aktuell.backCol(\"STDLIB_panelBackground\");
  setValue(\"aktuell\", \"enabled\", (bInput == TRUE)?bEnable:FALSE, 
                      \"editable\",(gbDirectInputIntoTextFields == TRUE)?bEnable:FALSE
          );
}
panelSetHighlighting(bool bHighlight)
{
}
panelSetValue(anytype aValue)
{
  if(getType(aValue) == BOOL_VAR)
    aktuell.text((int)aValue);
  else
    aktuell.text(aValue);
}
string mergeDPE(string dp, string dpe)
{
  string tDP = dp;
  string tDPE = dpe;
  if (substr(dp, strlen(dp)-1) == \".\")
    tDP = substr(dp, 0, strlen(dp)-1);
  
  if (substr(dpe, 0, 1) == \".\")
    tDPE = substr(dpe, 1);
  
  return tDP + \".\" + tDPE;
}
