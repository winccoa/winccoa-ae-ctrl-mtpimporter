"$__ENUM_Image"
"$__ENUM_ImageDef"
"$__ENUM_ImageDirection"
"$__ENUM_ShapeDirection"
"$__ENUM_ShapeForm"
"main()
{
  string sShowAlarm,sMsgCat,sMsgTolTip, sTmpDpe = $DPE;
  bool bUseDPEDescr;
  //get dollar parameter
  if($_INT_BIT!=\"\")
    iBit=$_INT_BIT;
  if($_BOOL_SHOWALARM!=\"\")
    bShowAlarm = strtolower ($_BOOL_SHOWALARM);
  if($_MSGTOOLTIP!=\"\")
    sMsgTolTip = $_MSGTOOLTIP;
  if($_MSGCAT!=\"\")
    sMsgCat    = $_MSGCAT;
  if($__ENUM_ShapeForm!=\"\")
    shapeForm = $__ENUM_ShapeForm;
  if ($__ENUM_ImageDirection!=\"\")
    imageRotation = $__ENUM_ImageDirection;
  if($_BIT_NUMBER!=\"\")
    iBitNumber = $_BIT_NUMBER;
  if($_BOOL_DPEDescrAsToolTip!=\"\")
      bUseDPEDescr = strtolower ($_BOOL_DPEDescrAsToolTip);
  if ($__ENUM_ImageDef!=\"\")
    sImageDef = strtolower ($__ENUM_ImageDef);

  splitDollarStr($__ENUM_Image, allImages, sizeImages);
  splitDollarStr($__ENUM_Color, allColors, sizeColors);

  isValid = ((sizeImages > 1) || (sizeColors > 1)) ? true : false;

  if (iBitNumber>=0 && strpos(sTmpDpe, \".pv\")>=0) //if a bitNr is given and node is pv then we want to connect to .bit
  {
    strreplace(sTmpDpe, \".pv\", \".bit\");
    sTmpDpe += iBitNumber;
  }

  sDPE=initializeElementarySymbolView($DP,sTmpDpe,$_DPE_Visible,$_RULE_Visible,$_DPE_Enable,$_RULE_Enable,$_DPE_Highlight,$_RULE_Highlight);
  langString lsDescr;
  if(sMsgTolTip!=\"\")
    symbol_image.toolTipText=getCatStr(sMsgCat,sMsgTolTip);
  else  if(bUseDPEDescr)
  {
    lsDescr = dpGetDescription(sDPE, 1);
    symbol_image.toolTipText(lsDescr);
  }
  if(bShowAlarm)
    dpConnect(\"alarm\",true,
                      sDPE+\":_alert_hdl.._act_state\",
                      sDPE+\":_alert_hdl.._act_state_color\");
}

splitDollarStr(string enumStr, dyn_string &ret, int &size)
{
  if (substr(enumStr, 0, 1) == \"|\")
    enumStr = substr(enumStr, 1);
  ret = strsplit(enumStr, '|');
  size = dynlen(ret);
}

alarm(string sDP3, bool bActiv, string sDP4, string sColor)
{
  if (bActiv)
  {
    bShowAlarmColors = true;
    setValue(getColorShapeName(), \"backCol\", sColor);
  }
  else
  {
    bShowAlarmColors = false;
    string val;
    dpGet(sDPE, val);
    setColor(val);
  }
}























" 0
