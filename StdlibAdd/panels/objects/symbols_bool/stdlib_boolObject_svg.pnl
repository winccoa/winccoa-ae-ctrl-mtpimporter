""0  1
E "mapping mLastState;
string sDPE;
int iBit = -1;
bool isValid = false;
bool useDirection = false;
bool bShowAlarm = false;
bool bShowAlarmColors = false;
dyn_string allImages, allColors;
int sizeImages, sizeColors;
string dir2, dir4;
int shapeForm;
string tmp1 = $__ENUM_ActState;
string tmp2 = $__ENUM_ShapeDirection;
string imageRotation;
int iBitNumber = -1; // setzt bei basicS7 readbin/writebin statt .pv ein .bitN bool - bitBit/iBit trotzdem drinnen lassen (cschnedl)
string sImageDef; // \"\", \"static\", \"dynamic\", \"dir2\", \"dir4\"
bool isOn;

panelSetVisibility(bool bVisible)
{
  symbol_image.visible(bVisible);
  setValue(getColorShapeName(), \"visible\", bVisible);
}
panelSetEnabled(bool bEnable)
{
  symbol_image.enabled(bEnable);
  updateSvgImage();
}
panelSetHighlighting(bool bHighlight)
{
}
panelSetValue(anytype curValue, bool bExec=false)
{ DebugN(\"panel value\", curValue, isOn);
  isOn = curValue;

  bool bVal;
  bool bUseBitNumber = false;
  if (getType(curValue) == BIT32_VAR)
  {
    bUseBitNumber = ((iBitNumber >= 0) && (iBitNumber < 32)) ? true : false;
    if (!bUseBitNumber)
    {
      isValid = false;
      throwError(makeError(\"stdlib\", PRIO_SEVERE, ERR_IMPL, 1101));
    }
  }

  if ((getType(curValue) != BOOL_VAR) && (iBit >= 0))
  {
    curValue = getBit((int)curValue, iBit);
  }
  else if (bUseBitNumber)
  {
    string dpType = dpTypeName(sDPE);
    string typeDPE;
    if (dpType == \"basicS7_readBin\")
      typeDPE = \".state.bit\";
    else if (dpType == \"basicS7_writeBin\")
      typeDPE = \".command.bit\";
    else
    {
      throwError(makeError(0, PRIO_SEVERE, ERR_PARAM, 0, sDPE, myManNum(), 0, \"BIT NUMBER not valid on \" + dpType));
      isValid = false;
    }

    string writeDPE = dpSubStr(sDPE, DPSUB_SYS_DP) + typeDPE + iBitNumber;
    if (dpExistsDPE(writeDPE))
    {
      bool dpeVal;
      dpGet(writeDPE, dpeVal);
      curValue = dpeVal;
    }
  }

  if (!isValid)
  {
    setValue(getColorShapeName(), \"backCol\", \"_dpdoesnotexist\");
    return;
  }

  setColor(curValue);
  setImage(curValue);
  updateSvgImage();
}

setColor(anytype curValue)
{
  if (bShowAlarmColors)
    return;

  if (sizeColors == 0)
  {
    setValue(getColorShapeName(), \"backCol\", \"_Transparent\");
    return;
  }

  int idx = curValue ? 1 : 2;

  string col;
  if ((idx >= 0) && (sizeColors != 1))
    col = allColors[idx];
  else if (idx >= 0)
    col = allColors[1];
  else if (idx == -1)
  {
    col = \"_dpdoesnotexist\";
    myThrowError(PRIO_WARNING, 1);
  }
  setValue(getColorShapeName(), \"backCol\", col);

}

setImage(anytype curValue)
{
  isOn = curValue;
  if (sizeImages == 0)
  {
    symbol_image.fill(\"[outline]\");
    return;
  }
  if (sizeImages == 1)
  {
    symbol_image.fill(getFillStr(allImages[1]));
    return;
  }

  int idx = -1;
  if ((sImageDef == \"dir2\") || (sImageDef == \"dir4\"))
  {
    idx = getRotationIdx();
  }
  else
  {
    idx = curValue ? 1 : 2;
    if (sImageDef == \"dyndir4\") // idx = multifier, starting at 0
    {
      idx = (idx-1)*4 + getRotationIdx();
    }
    else if (sImageDef == \"dyndir2\") // idx = multifier, starting at 0
    {
      idx = (idx-1)*2 + getRotationIdx();
    }
  }
  string img;
  if (idx >= 0)
    img = getFillStr(allImages[idx]);
  else
  {
    img = \"[outline]\";
    myThrowError(PRIO_WARNING, 1);
  }
  symbol_image.fill(img);
  updateSvgImage();
}
updateSvgImage()
{
  string color = \"fp_elemSymbol_\" + (isOn ? \"on\" : \"off\") +(symbol_image.enabled ? \"\": \"Disabled\");
  symbol_image.fillSvgElement(\"rBackground\", \"[solid]\", color);
}

int getRotationIdx()
{
  int idx;
  switch(imageRotation)
  {
    case \"up\":
    case \"vertical\":
      idx = 1;
      break;
    case \"down\":
    case \"horizontal\":
      idx = 2;
      break;
    case \"left\":
      idx = 3;
      break;
    case \"right\":
      idx = 4;
      break;
    default:
      if (sImageDef == \"dir2\")
        idx = 2; // horizontal;
      else if (sImageDef == \"dir4\")
        idx = 1;
      idx = 1;
  }

  return idx;
}

string getFillStr(string imgPath)
{
  string ret = \"[pattern,[fit,any,pictures/\" + imgPath + \"]]\";
  return ret;
}

string getColorShapeName()
{
  switch (shapeForm)
  {
    case 0:
      return \"symbol_rect\";
      break;
    case 1:
      return \"symbol_circ\";
      break;
    case 2:
      return \"symbol_poly\";
      break;
  }
}

myThrowError(int prio, int code)
{
  errClass err = makeError(\"stdlib_error\", prio, ERR_IMPL, code);
  throwError(err);
}






































































